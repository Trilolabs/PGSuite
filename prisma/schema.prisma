// PG Dashboard - Full Prisma Schema
// 11 models covering all data entities

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ===================== PROPERTY =====================
model Property {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  totalRooms    Int      @default(0)
  totalBeds     Int      @default(0)
  occupiedBeds  Int      @default(0)
  activeTenants Int      @default(0)
  underNotice   Int      @default(0)
  pendingDues   Float    @default(0)
  collection    Float    @default(0)
  floors        Int      @default(1)
  address       String   @default("")
  type          String   @default("PG")
  gender        String   @default("Male")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rooms        Room[]
  tenants      Tenant[]
  staff        Staff[]
  expenses     Expense[]
  bookings     Booking[]
  oldTenants   OldTenant[]
  complaints   Complaint[]
  dues         Due[]
  collections  Collection[]
  leads        Lead[]
  duesPackages DuesPackage[]
}

// ===================== ROOM =====================
model Room {
  id           String   @id @default(cuid())
  number       String
  floor        String
  beds         Int      @default(1)
  occupiedBeds Int      @default(0)
  type         String   @default("Single")
  rent         Float    @default(0)
  status       String   @default("Vacant")
  amenities    String   @default("[]") // JSON array stored as string
  remarks      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants    Tenant[]

  @@unique([number, propertyId])
}

// ===================== TENANT =====================
model Tenant {
  id               String   @id @default(cuid())
  name             String
  phone            String
  email            String   @default("")
  moveIn           String
  rent             Float
  deposit          Float    @default(0)
  kycStatus        String   @default("Pending")
  appStatus        String   @default("Active")
  stayType         String   @default("Monthly")
  tenantType       String   @default("Student")
  noticePeriod     Int      @default(30)
  lockIn           Int      @default(0) // Added Gap Fill
  agreementPeriod  Int      @default(11) // Added Gap Fill
  moveOut          String?  // Added Gap Fill
  idProof          String   @default("")
  idProofType      String   @default("") // Added
  idProofNumber    String   @default("") // Added
  emergencyContact String   @default("")
  floor            String   @default("")
  bed              String   @default("")
  createdAt        DateTime @default(now())
  dob              String   @default("")
  gender           String   @default("Male")
  bloodGroup       String   @default("")
  foodPreference   String   @default("")
  company          String   @default("")
  designation      String   @default("")
  aadhar           String   @default("")
  pan              String   @default("")
  currentAddress   String   @default("")
  permanentAddress String   @default("")
  maintenance      Float    @default(0)
  joiningFee       Float    @default(0)
  rentalFrequency  String   @default("Monthly")
  rentStartDate    String   @default("1")
  checkInTime      String   @default("")     // Added for Deep Parity
  checkOutTime     String   @default("")     // Added for Deep Parity
  electricityType  String   @default("Fixed Amount")
  electricityRate  Float    @default(0)
  openingBalance   Float    @default(0)
  paymentMode      String   @default("Cash")
  updatedAt        DateTime @updatedAt

  // Extended Details
  remarks          String   @default("")
  nationality      String   @default("Indian")
  gstNo            String   @default("")
  gstAddress       String   @default("")
  photo            String   @default("") // Profile Photo
  fatherName       String   @default("")
  fatherPhone      String   @default("")
  fatherOccupation String   @default("") // Added
  motherName       String   @default("")
  motherPhone      String   @default("")
  motherOccupation String   @default("") // Added
  guardianName     String   @default("")
  guardianPhone    String   @default("")
  bankName         String   @default("")
  accountNumber    String   @default("")
  ifscCode         String   @default("")
  upiId            String   @default("") // Added
  meterNumber      String   @default("") // Added
  initialMeterReading Float @default(0)  
  lastMeterReading    Float @default(0)  // Added
  documents        String   @default("[]") // JSON array for ID Proofs etc.

  bookedBy         String   @default("")
  referredBy       String   @default("")

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomId     String?
  room       Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  dues        Due[]
  collections Collection[]
  complaints  Complaint[]
}

// ===================== DUE =====================
model Due {
  id      String @id @default(cuid())
  type    String
  amount  Float
  dueDate String
  status  String @default("Unpaid")

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== COLLECTION =====================
model Collection {
  id         String @id @default(cuid())
  date       String
  amount     Float
  mode       String @default("Cash")
  receivedBy String @default("Admin")
  receipt    String @default("")

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ===================== EXPENSE =====================
model Expense {
  id          String  @id @default(cuid())
  date        String
  category    String
  description String  @default("")
  amount      Float
  hasReceipt  Boolean @default(false)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ===================== DUES PACKAGE =====================
model DuesPackage {
  id          String  @id @default(cuid())
  name        String
  type        String  @default("Fixed")
  amount      Float?
  frequency   String  @default("Monthly") // Added
  deposit     Float   @default(0)         // Added
  status      String  @default("Active")  // Renamed/Standardized from enabled/active logic if needed, keeping simple text
  active      Boolean @default(true)      // Keeping for backward compat or easy toggle
  description String  @default("")

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ===================== BOOKING =====================
model Booking {
  id          String @id @default(cuid())
  name        String
  phone       String
  room        String
  bookingDate String
  moveInDate  String
  amount      Float  @default(0)
  advancePaid Float  @default(0)
  status      String @default("Pending")

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== OLD TENANT =====================
model OldTenant {
  id              String  @id @default(cuid())
  name            String
  phone           String
  room            String
  moveIn          String
  moveOut         String
  totalStay       String  @default("")
  pendingDues     Float   @default(0)
  pendingAmount   Float   @default(0)
  settlement      String  @default("Pending Settlement")
  depositRefunded Boolean @default(false)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ===================== STAFF =====================
model Staff {
  id       String @id @default(cuid())
  name     String
  phone    String
  role     String
  salary   Float  @default(0)
  joinDate String
  status   String @default("Active")

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ===================== COMPLAINT =====================
model Complaint {
  id          String @id @default(cuid())
  category    String
  description String @default("")
  status      String @default("Open")
  priority    String @default("Medium")
  date        String
  room        String @default("")

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ===================== LEAD =====================
model Lead {
  id         String @id @default(cuid())
  name       String
  phone      String
  budget     String @default("")
  sharing    String @default("")
  facilities String @default("")
  status     String @default("New")
  source     String @default("Website")
  addedOn    String
  addedBy    String @default("Admin")

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
